<!DOCTYPE html>
<html lang="<%= locale %>">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <%- helpers.seoHead(pageMeta) %>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="shortcut icon" href="/favicon.svg">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Fira+Code:wght@400;500;600;700&family=Share+Tech+Mono&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/style.css">
  <% if (features.search) { %>
  <link rel="stylesheet" href="/search.css">
  <% } %>
  <% if (features.categories) { %>
  <link rel="stylesheet" href="/taxonomy.css">
  <% } %>
</head>
<body class="cyber-theme">
  <!-- Scanline Overlay -->
  <div class="scanlines"></div>

  <header class="blog-header terminal-panel">
    <div class="header-container">
      <div class="terminal-header">
        <span class="btn-dot close"></span>
        <span class="btn-dot shrink"></span>
        <span class="btn-dot expand"></span>
        <span class="terminal-title"><%= helpers.copy('terminalTitle', 'zenith_press_kernel.sys') %></span>
      </div>
      <div class="terminal-body">
        <h1 class="logo"><a href="/index.html">>_ <%= siteName %></a></h1>
        <p class="subtitle"><%= helpers.copy('statusLabel', 'System Status: ONLINE') %> | <%= siteSubtitle %></p>
      </div>
    </div>
  </header>

  <div class="main-layout">
    <main class="posts-feed">
      <% if (features.search) { %>
      <section class="search-panel" role="search" data-search-panel data-search-empty="<%= helpers.copy('searchNoResults', 'No matching posts found.') %>">
        <label class="search-label" for="site-search"><%= helpers.copy('searchLabel', 'Search Archive') %></label>
        <input id="site-search" class="search-input" type="search" data-search-input placeholder="<%= helpers.copy('searchPlaceholder', 'Search posts, categories, or tags...') %>" autocomplete="off">
        <div class="search-results" data-search-results aria-live="polite"></div>
      </section>
      <% } %>
      <%- helpers.categoryArchiveHeader(currentCategory) %>

      <% if (posts.length === 0) { %>
        <div class="empty-state terminal-panel">
          <p><%= helpers.copy('emptyState', '[ERROR: NO_POSTS_FOUND_IN_SECTOR]') %></p>
        </div>
      <% } else { %>
        <% posts.forEach((post, index) => { %>
          <article class="post-card terminal-panel" data-search-card data-search-text="<%= [post.title, post.description, post.categoryName, ...((post.tags || []))].join(' ') %>">
            <div class="terminal-header">
              <span class="terminal-file-icon"></span>
              <span class="terminal-title">post://<%= post.slug %>.md</span>
            </div>
            <div class="terminal-body">
              <% if (post.coverImage) { %>
                <div class="post-image-container">
                  <a href="/posts/<%= post.slug %>/index.html">
                    <img src="<%= post.coverImage %>" alt="<%= post.title %>" class="post-cover" loading="<%= index === 0 ? 'eager' : 'lazy' %>" decoding="async" fetchpriority="<%= index === 0 ? 'high' : 'auto' %>">
                  </a>
                </div>
              <% } %>
              <div class="post-meta">
                <%- helpers.categoryLink(post, { prefix: '[', suffix: ']' }) %>
                <span class="meta-divider">::</span>
                <time class="post-date" datetime="<%= helpers.isoDate(post.date) %>"><%= helpers.date(post.date) %></time>
              </div>
              <h2 class="post-title">
                <a href="/posts/<%= post.slug %>/index.html"><%= post.title %></a>
              </h2>
              <p class="post-excerpt">> <%= post.description %></p>
              <div class="action-row">
                <a href="/posts/<%= post.slug %>/index.html" class="read-more"><%= helpers.copy('readMoreLabel', '[ EXECUTE_POST_READER ]') %></a>
              </div>
            </div>
          </article>
        <% }) %>
      <% } %>
    </main>

    <aside class="blog-sidebar">
      <%- helpers.categoryNav(categories, currentCategory, { className: 'widget widget-categories terminal-panel', titlePrefix: '>_ ' }) %>
      <% widgets.filter(w => w.enabled && w.position === 'sidebar').forEach(widget => { %>
        <div class="widget widget-<%= widget.type %> terminal-panel" id="widget-<%= widget.id %>">
          <div class="terminal-header">
            <span class="terminal-title">widget://<%= widget.id %>.conf</span>
          </div>
          <div class="terminal-body">
            <h3 class="widget-title">>_ <%= widget.name %></h3>
            
            <% if (widget.type === 'bio') { %>
              <div class="bio-content">
                <% if (authorAvatar) { %>
                  <img src="<%= authorAvatar %>" alt="<%= authorName %>" class="bio-avatar" loading="lazy" decoding="async">
                <% } %>
                <h4 class="bio-name"><%= helpers.t('NAME:') %> <%= authorName %></h4>
                <p class="bio-text"><%= authorBio %></p>
                <div class="bio-socials">
                  <% if (socialLinks.github) { %><a href="<%= socialLinks.github %>" target="_blank" rel="noopener">[GITHUB]</a><% } %>
                  <% if (socialLinks.twitter) { %><a href="<%= socialLinks.twitter %>" target="_blank" rel="noopener">[TWITTER]</a><% } %>
                  <% if (socialLinks.linkedin) { %><a href="<%= socialLinks.linkedin %>" target="_blank" rel="noopener">[LINKEDIN]</a><% } %>
                  <% if (socialLinks.instagram) { %><a href="<%= socialLinks.instagram %>" target="_blank" rel="noopener">[INSTAGRAM]</a><% } %>
                </div>
              </div>
            <% } else if (widget.type === 'recent-posts') { %>
              <ul class="recent-posts-list">
                <% posts.slice(0, 5).forEach(p => { %>
                  <li>
                    <a href="/posts/<%= p.slug %>/index.html" class="recent-post-link">-> <%= p.title %></a>
                    <time class="recent-post-date" datetime="<%= helpers.isoDate(p.date) %>">[<%= helpers.date(p.date) %>]</time>
                  </li>
                <% }) %>
              </ul>
            <% } else if (widget.type === 'tag-cloud') { %>
              <div class="tag-cloud">
                <% 
                  const tags = {};
                  posts.forEach(p => {
                    if (p.tags) p.tags.forEach(t => { tags[t] = (tags[t] || 0) + 1 })
                  });
                %>
                <% Object.keys(tags).forEach(tag => { %>
                  <span class="tag-chip">#<%= tag %>:<%= tags[tag] %></span>
                <% }) %>
              </div>
            <% } else if (widget.type === 'custom-html') { %>
              <div class="custom-html">
                <%- widget.htmlContent || '' %>
              </div>
            <% } %>
          </div>
        </div>
      <% }) %>
    </aside>
  </div>

  <footer class="blog-footer terminal-panel">
    <div class="terminal-header">
      <span class="terminal-title"><%= helpers.copy('footerTerminalTitle', 'system://shutdown.log') %></span>
    </div>
    <div class="terminal-body">
      <div class="footer-container">
        <div class="footer-widgets">
          <% widgets.filter(w => w.enabled && w.position === 'footer').forEach(widget => { %>
            <div class="widget widget-<%= widget.type %>" id="widget-<%= widget.id %>">
              <h4 class="widget-title">>_ <%= widget.name %></h4>
              <% if (widget.type === 'newsletter') { %>
                <div class="newsletter-content">
                  <p><%= helpers.copy('newsletterDescription', 'CONNECT TO SECTOR NEWSLETTER STREAM.') %></p>
                  <% if (widget.actionUrl) { %>
                    <form class="newsletter-form" action="<%= widget.actionUrl %>" method="post">
                      <input type="email" name="email" placeholder="<%= widget.placeholderText || helpers.copy('newsletterPlaceholder', 'admin@domain.com') %>" required aria-label="<%= helpers.copy('newsletterEmailLabel', 'Terminal Email Address') %>">
                      <button type="submit"><%= helpers.copy('newsletterSubmitLabel', '[ INJECT ]') %></button>
                    </form>
                  <% } else { %>
                    <form class="newsletter-form">
                      <input type="email" placeholder="<%= helpers.copy('newsletterDisabledPlaceholder', 'CONFIGURE_ENDPOINT') %>" disabled aria-label="<%= helpers.copy('newsletterEmailLabel', 'Terminal Email Address') %>">
                      <button type="button" disabled><%= helpers.copy('newsletterDisabledLabel', '[ CONFIG ]') %></button>
                    </form>
                  <% } %>
                </div>
              <% } else if (widget.type === 'custom-html') { %>
                <div class="custom-html">
                  <%- widget.htmlContent || '' %>
                </div>
              <% } %>
            </div>
          <% }) %>
        </div>
        <div class="footer-bottom">
          <p>&copy;&nbsp;<%= new Date().getFullYear() %>&nbsp;<%= String(siteName || '').toUpperCase().replace(' ', '_') %>_KERNEL. <%= helpers.copy('footerRights', 'ALL RIGHTS SECURED.') %></p>
          <p class="credit"><%= helpers.copy('footerCreditLabel', 'COMPILED_BY:') %> <a href="<%= helpers.copy('footerCreditUrl', '#') %>" class="footer-link"><%= helpers.copy('footerCreditText', '[ZENITH_PRESS]') %></a></p>
        </div>
      </div>
    </div>
  </footer>
  <% if (features.search) { %>
  <script src="/search.js" defer></script>
  <% } %>
  <%- helpers.consentDialog() %>
</body>
</html>
