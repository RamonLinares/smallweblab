<!DOCTYPE html>
<html lang="<%= locale %>">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <%- helpers.seoHead(pageMeta) %>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="shortcut icon" href="/favicon.svg">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;700&family=Syne:wght@500;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/style.css">
  <% if (features.search) { %>
  <link rel="stylesheet" href="/search.css">
  <% } %>
  <% if (features.categories) { %>
  <link rel="stylesheet" href="/taxonomy.css">
  <% } %>
</head>
<body class="brutalist-theme">
  <div class="newspaper-top-bar">
    <span><%= helpers.t('VOL.') %> <%= new Date().getFullYear() - 2020 %> <%= helpers.t('NO.') %> <%= new Date().getMonth() + 1 %></span>
    <span class="pulse-marquee"><%= helpers.copy('editionLabel', 'EDITION: DIGITAL AESTHETICS') %></span>
    <span><%= helpers.upper(helpers.longDate(new Date())) %></span>
  </div>

  <header class="blog-header brutalist-border-bottom">
    <div class="header-container">
      <p class="logo"><a href="/index.html"><%= siteName %></a></p>
      <p class="subtitle"><%= String(siteSubtitle || '').toUpperCase() %></p>
    </div>
  </header>

  <div class="main-layout single-post-layout animate-slide-up">
    <main class="post-detail">
      <nav class="back-nav">
        <a href="/index.html" class="back-link"><%= helpers.copy('backLinkLabel', '← BACK TO GAZETTE DIRECTORY') %></a>
      </nav>

      <article class="full-post brutalist-card">
        <div class="post-meta">
          <%- helpers.categoryLink(post, { upper: true }) %>
          <span class="meta-divider">/</span>
          <time class="post-date" datetime="<%= helpers.isoDate(post.date) %>"><%= helpers.date(post.date) %></time>
        </div>

        <h1 class="post-title"><%= post.title %></h1>
        <p class="post-description"><%= post.description %></p>

        <% if (post.coverImage) { %>
          <div class="post-cover-container">
            <img src="<%= post.coverImage %>" alt="<%= post.title %>" class="post-detail-cover" loading="eager" decoding="async" fetchpriority="high">
          </div>
        <% } %>

        <div class="post-content markdown-body">
          <%- post.content %>
        </div>
      </article>
    </main>

    <aside class="blog-sidebar">
      <%- helpers.categoryNav(categories, post, { className: 'widget widget-categories brutalist-card' }) %>
      <% widgets.filter(w => w.enabled && w.position === 'sidebar').forEach(widget => { %>
        <div class="widget widget-<%= widget.type %> brutalist-card" id="widget-<%= widget.id %>">
          <h3 class="widget-title"><%= widget.name %></h3>

          <% if (widget.type === 'bio') { %>
            <div class="bio-content">
              <% if (authorAvatar) { %>
                <div class="avatar-holder">
                  <img src="<%= authorAvatar %>" alt="<%= authorName %>" class="bio-avatar" loading="lazy" decoding="async">
                </div>
              <% } %>
              <h4 class="bio-name"><%= authorName %></h4>
              <p class="bio-text"><%= authorBio %></p>
              <div class="bio-socials">
                <% if (socialLinks.github) { %><a href="<%= socialLinks.github %>" target="_blank" rel="noopener">GITHUB</a><% } %>
                <% if (socialLinks.twitter) { %><a href="<%= socialLinks.twitter %>" target="_blank" rel="noopener">TWITTER</a><% } %>
                <% if (socialLinks.linkedin) { %><a href="<%= socialLinks.linkedin %>" target="_blank" rel="noopener">LINKEDIN</a><% } %>
                <% if (socialLinks.instagram) { %><a href="<%= socialLinks.instagram %>" target="_blank" rel="noopener">INSTAGRAM</a><% } %>
              </div>
            </div>
          <% } else if (widget.type === 'recent-posts') { %>
            <ul class="recent-posts-list">
              <% posts.slice(0, 5).forEach(p => { %>
                <li>
                  <a href="/posts/<%= p.slug %>/index.html" class="recent-post-link">&bull; <%= p.title %></a>
                  <time class="recent-post-date" datetime="<%= helpers.isoDate(p.date) %>"><%= helpers.date(p.date) %></time>
                </li>
              <% }) %>
            </ul>
          <% } else if (widget.type === 'tag-cloud') { %>
            <div class="tag-cloud">
              <%
                const tags = {};
                posts.forEach(p => {
                  if (p.tags) p.tags.forEach(t => { tags[t] = (tags[t] || 0) + 1 })
                });
              %>
              <% Object.keys(tags).forEach(tag => { %>
                <span class="tag-chip"><%= tag %> (<%= tags[tag] %>)</span>
              <% }) %>
            </div>
          <% } else if (widget.type === 'custom-html') { %>
            <div class="custom-html-content">
              <%- widget.htmlContent || '' %>
            </div>
          <% } %>
        </div>
      <% }) %>
    </aside>
  </div>

  <footer class="blog-footer brutalist-border-top">
    <div class="footer-container">
      <div class="footer-widgets">
        <% widgets.filter(w => w.enabled && w.position === 'footer').forEach(widget => { %>
          <div class="widget widget-<%= widget.type %> brutalist-card" id="widget-<%= widget.id %>">
            <h4 class="widget-title"><%= widget.name %></h4>
            <% if (widget.type === 'newsletter') { %>
              <div class="newsletter-content">
                <p><%= helpers.copy('newsletterDescription', 'Subscribe to our wire updates. Delivered instantly to your visual cortex.') %></p>
                <% if (widget.actionUrl) { %>
                  <form class="newsletter-form" action="<%= widget.actionUrl %>" method="post">
                    <input type="email" name="email" placeholder="<%= widget.placeholderText || helpers.copy('newsletterPlaceholder', 'your.email@wire.com') %>" required aria-label="<%= helpers.copy('newsletterEmailLabel', 'Newsletter input') %>">
                    <button type="submit"><%= helpers.copy('newsletterSubmitLabel', 'SUBSCRIBE') %></button>
                  </form>
                <% } else { %>
                  <form class="newsletter-form">
                    <input type="email" placeholder="<%= helpers.copy('newsletterDisabledPlaceholder', 'CONFIGURE WIRE ENDPOINT') %>" disabled aria-label="<%= helpers.copy('newsletterEmailLabel', 'Newsletter input') %>">
                    <button type="button" disabled><%= helpers.copy('newsletterDisabledLabel', 'CONFIGURE') %></button>
                  </form>
                <% } %>
              </div>
            <% } else if (widget.type === 'custom-html') { %>
              <div class="custom-html-content">
                <%- widget.htmlContent || '' %>
              </div>
            <% } %>
          </div>
        <% }) %>
      </div>
      <div class="footer-bottom">
        <p>&copy; <%= new Date().getFullYear() %> <%= String(siteName || '').toUpperCase() %>. <%= helpers.copy('footerRights', 'UNCOMPROMISING DIGITAL DISPATCH.') %></p>
        <p class="credit"><%= helpers.copy('footerCreditLabel', 'POWERED BY') %> <a href="<%= helpers.copy('footerCreditUrl', '#') %>" class="footer-link"><%= helpers.copy('footerCreditText', 'ZENITH_PRESS') %></a></p>
      </div>
    </div>
  </footer>
  <%- helpers.consentDialog() %>
</body>
</html>
