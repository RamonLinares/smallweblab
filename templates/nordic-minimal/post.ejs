<!DOCTYPE html>
<html lang="<%= locale %>">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <%- helpers.seoHead(pageMeta) %>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="shortcut icon" href="/favicon.svg">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/style.css">
  <% if (features.search) { %>
  <link rel="stylesheet" href="/search.css">
  <% } %>
  <% if (features.categories) { %>
  <link rel="stylesheet" href="/taxonomy.css">
  <% } %>
</head>
<body>
  <header class="blog-header">
    <div class="header-container">
      <p class="logo"><a href="/index.html"><%= siteName %></a></p>
      <p class="subtitle"><%= siteSubtitle %></p>
    </div>
  </header>

  <div class="main-layout single-post-layout">
    <main class="post-detail">
      <nav class="back-nav">
        <a href="/index.html" class="back-link"><%= helpers.copy('backLinkLabel', '← Back to Musings') %></a>
      </nav>

      <article class="full-post">
        <div class="post-meta">
          <%- helpers.categoryLink(post) %>
          <span class="meta-divider">•</span>
          <time class="post-date" datetime="<%= helpers.isoDate(post.date) %>"><%= helpers.date(post.date) %></time>
        </div>

        <h1 class="post-title"><%= post.title %></h1>
        <p class="post-description"><%= post.description %></p>

        <% if (post.coverImage) { %>
          <div class="post-cover-container">
            <img src="<%= post.coverImage %>" alt="<%= post.title %>" class="post-detail-cover" loading="eager" decoding="async" fetchpriority="high">
          </div>
        <% } %>

        <div class="post-content markdown-body">
          <%- post.content %>
        </div>
      </article>
    </main>

    <aside class="blog-sidebar">
      <%- helpers.categoryNav(categories, post) %>
      <% widgets.filter(w => w.enabled && w.position === 'sidebar').forEach(widget => { %>
        <div class="widget widget-<%= widget.type %>" id="widget-<%= widget.id %>">
          <h3 class="widget-title"><%= widget.name %></h3>

          <% if (widget.type === 'bio') { %>
            <div class="bio-content">
              <% if (authorAvatar) { %>
                <img src="<%= authorAvatar %>" alt="<%= authorName %>" class="bio-avatar" loading="lazy" decoding="async">
              <% } %>
              <h4 class="bio-name"><%= authorName %></h4>
              <p class="bio-text"><%= authorBio %></p>
              <div class="bio-socials">
                <% if (socialLinks.github) { %><a href="<%= socialLinks.github %>" target="_blank" rel="noopener">GitHub</a><% } %>
                <% if (socialLinks.twitter) { %><a href="<%= socialLinks.twitter %>" target="_blank" rel="noopener">Twitter</a><% } %>
                <% if (socialLinks.linkedin) { %><a href="<%= socialLinks.linkedin %>" target="_blank" rel="noopener">LinkedIn</a><% } %>
                <% if (socialLinks.instagram) { %><a href="<%= socialLinks.instagram %>" target="_blank" rel="noopener">Instagram</a><% } %>
              </div>
            </div>
          <% } else if (widget.type === 'recent-posts') { %>
            <ul class="recent-posts-list">
              <% posts.slice(0, 5).forEach(p => { %>
                <li>
                  <a href="/posts/<%= p.slug %>/index.html" class="recent-post-link"><%= p.title %></a>
                  <time class="recent-post-date" datetime="<%= helpers.isoDate(p.date) %>"><%= helpers.date(p.date) %></time>
                </li>
              <% }) %>
            </ul>
          <% } else if (widget.type === 'tag-cloud') { %>
            <div class="tag-cloud">
              <%
                const tags = {};
                posts.forEach(p => {
                  if (p.tags) p.tags.forEach(t => { tags[t] = (tags[t] || 0) + 1 })
                });
              %>
              <% Object.keys(tags).forEach(tag => { %>
                <span class="tag-chip"><%= tag %> (<%= tags[tag] %>)</span>
              <% }) %>
            </div>
          <% } else if (widget.type === 'custom-html') { %>
            <div class="custom-html">
              <%- widget.htmlContent || '' %>
            </div>
          <% } %>
        </div>
      <% }) %>
    </aside>
  </div>

  <footer class="blog-footer">
    <div class="footer-container">
      <div class="footer-widgets">
        <% widgets.filter(w => w.enabled && w.position === 'footer').forEach(widget => { %>
          <div class="widget widget-<%= widget.type %>" id="widget-<%= widget.id %>">
            <h4 class="widget-title"><%= widget.name %></h4>
            <% if (widget.type === 'newsletter') { %>
              <div class="newsletter-content">
                <p><%= helpers.copy('newsletterDescription', 'Subscribe for the latest design & dev updates directly to your inbox.') %></p>
                <% if (widget.actionUrl) { %>
                  <form class="newsletter-form" action="<%= widget.actionUrl %>" method="post">
                    <input type="email" name="email" placeholder="<%= widget.placeholderText || helpers.copy('newsletterPlaceholder', 'Your email address') %>" required aria-label="<%= helpers.copy('newsletterEmailLabel', 'Email Address') %>">
                    <button type="submit"><%= helpers.copy('newsletterSubmitLabel', 'Subscribe') %></button>
                  </form>
                <% } else { %>
                  <form class="newsletter-form">
                    <input type="email" placeholder="<%= helpers.copy('newsletterDisabledPlaceholder', 'Configure newsletter endpoint') %>" disabled aria-label="<%= helpers.copy('newsletterEmailLabel', 'Email Address') %>">
                    <button type="button" disabled><%= helpers.copy('newsletterDisabledLabel', 'Configure') %></button>
                  </form>
                <% } %>
              </div>
            <% } else if (widget.type === 'custom-html') { %>
              <div class="custom-html">
                <%- widget.htmlContent || '' %>
              </div>
            <% } %>
          </div>
        <% }) %>
      </div>
      <div class="footer-bottom">
        <p>&copy; <%= new Date().getFullYear() %> <%= siteName %>. <%= helpers.copy('footerRights', 'All rights reserved.') %></p>
        <p class="credit"><%= helpers.copy('footerCreditLabel', 'Powered by') %> <a href="<%= helpers.copy('footerCreditUrl', '#') %>" class="footer-link"><%= helpers.copy('footerCreditText', 'ZenithPress') %></a></p>
      </div>
    </div>
  </footer>
  <%- helpers.consentDialog() %>
</body>
</html>
